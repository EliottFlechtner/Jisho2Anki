# Copy this file to .env and customize.
# Any ANKI_JISHO2ANKI_* value can be overridden by CLI flags or form inputs.

ANKI_JISHO2ANKI_INPUT=words.txt
ANKI_JISHO2ANKI_OUTPUT_PATH=anki_import.tsv
ANKI_JISHO2ANKI_INCLUDE_HEADER=true
ANKI_JISHO2ANKI_PAUSE_SECONDS=0
ANKI_JISHO2ANKI_MAX_WORKERS=6
ANKI_JISHO2ANKI_INTERACTIVE_REVIEW=false
ANKI_JISHO2ANKI_CANDIDATE_LIMIT=3
ANKI_JISHO2ANKI_SENTENCE_COUNT=2
ANKI_JISHO2ANKI_SEPARATE_SENTENCE_CARDS=false
ANKI_JISHO2ANKI_INCLUDE_SENTENCES=true
ANKI_JISHO2ANKI_INCLUDE_PITCH_ACCENT=true
ANKI_JISHO2ANKI_ANKI_CONNECT=true
ANKI_JISHO2ANKI_ANKI_URL=http://127.0.0.1:8765
ANKI_JISHO2ANKI_DECK_NAME=Example
ANKI_JISHO2ANKI_MODEL_NAME=Japanese (Basic & Reversed)
ANKI_JISHO2ANKI_FIELD_WORD=Expression
ANKI_JISHO2ANKI_FIELD_MEANING=Meaning
ANKI_JISHO2ANKI_FIELD_READING=Reading
ANKI_JISHO2ANKI_TAGS=
ANKI_JISHO2ANKI_ALLOW_DUPLICATES=false
ANKI_JISHO2ANKI_SENTENCE_DECK_NAME=Example::Examples
ANKI_JISHO2ANKI_SENTENCE_MODEL_NAME=Basic
ANKI_JISHO2ANKI_SENTENCE_FRONT_FIELD=Front
ANKI_JISHO2ANKI_SENTENCE_BACK_FIELD=Back
ANKI_JISHO2ANKI_VITE_DEV_SERVER_URL=
