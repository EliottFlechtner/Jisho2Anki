# Copy to .env.docker if you want compose-specific overrides.
APP_PORT=5000

# Optional presets/default behavior.
# ANKI_AUTOFILLER_PRESET=fast-import

# In Docker, use host.docker.internal to reach desktop AnkiConnect.
ANKI_AUTOFILLER_ANKI_URL=http://host.docker.internal:8765

# Where TSV output is written inside the container.
ANKI_AUTOFILLER_OUTPUT_PATH=/app/output/anki_import.tsv
