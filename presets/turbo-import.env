# Fastest bulk import when API/network are stable
ANKI_AUTOFILLER_PAUSE_SECONDS=0
ANKI_AUTOFILLER_MAX_WORKERS=12
ANKI_AUTOFILLER_INTERACTIVE_REVIEW=false
ANKI_AUTOFILLER_CANDIDATE_LIMIT=2
ANKI_AUTOFILLER_SENTENCE_COUNT=1
ANKI_AUTOFILLER_INCLUDE_SENTENCES=true
ANKI_AUTOFILLER_INCLUDE_PITCH_ACCENT=true
ANKI_AUTOFILLER_SEPARATE_SENTENCE_CARDS=false
ANKI_AUTOFILLER_ANKI_CONNECT=true
