# Better quality selection, slower but safer
ANKI_AUTOFILLER_PAUSE_SECONDS=0.25
ANKI_AUTOFILLER_MAX_WORKERS=3
ANKI_AUTOFILLER_INTERACTIVE_REVIEW=true
ANKI_AUTOFILLER_CANDIDATE_LIMIT=6
ANKI_AUTOFILLER_SENTENCE_COUNT=3
ANKI_AUTOFILLER_INCLUDE_SENTENCES=true
ANKI_AUTOFILLER_INCLUDE_PITCH_ACCENT=true
ANKI_AUTOFILLER_SEPARATE_SENTENCE_CARDS=false
ANKI_AUTOFILLER_ANKI_CONNECT=true
